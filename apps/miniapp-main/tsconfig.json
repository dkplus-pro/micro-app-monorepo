{
  "extends": "@ai-mind-clone/tsconfig/uniapp.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ai-mind-clone/request": ["../../packages/request/src/index.ts"],
      "@ai-mind-clone/utils": ["../../packages/utils/src/index.ts"],
